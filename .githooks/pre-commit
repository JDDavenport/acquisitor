#!/bin/bash
# Pre-commit hook - Enforce code quality standards

set -e

STAGED_FILES=$(git diff --cached --name-only)

# 1. Check diff size (warn if >500 lines)
DIFF_LINES=$(git diff --cached --stat | tail -1 | awk '{print $NF}' | grep -o '[0-9]*' | head -1)
if [ -n "$DIFF_LINES" ] && [ "$DIFF_LINES" -gt 500 ]; then
  echo "⚠️  WARNING: Large commit detected ($DIFF_LINES lines changed)"
  echo "    Consider breaking this into smaller commits for clarity"
fi

# 2. Check for hardcoded secrets (API keys, tokens, passwords)
SECRET_PATTERNS=(
  "api[_-]?key\s*[:=]"
  "secret[_-]?key\s*[:=]"
  "password\s*[:=]"
  "token\s*[:=]"
  "authorization\s*[:=]"
  "bearer\s+"
  "aws_access_key"
  "aws_secret"
)

FOUND_SECRETS=false
for pattern in "${SECRET_PATTERNS[@]}"; do
  if git diff --cached -U0 | grep -iE "$pattern" > /dev/null; then
    FOUND_SECRETS=true
    echo "🔒 BLOCKED: Potential hardcoded secret detected"
    echo "   Matching pattern: $pattern"
    git diff --cached -U0 | grep -iE "$pattern" | head -3
    echo ""
  fi
done

if [ "$FOUND_SECRETS" = true ]; then
  echo "❌ Commit blocked: Remove secrets before committing"
  exit 1
fi

# 3. Run build (npm run build or equivalent)
if [ -f "package.json" ]; then
  echo "🔨 Building..."
  if ! npm run build 2>&1 | tail -5; then
    echo "❌ Build failed: Fix errors before committing"
    exit 1
  fi
fi

# 4. Check for banned patterns in commit messages (warning only, msg hook enforces)
# This is advisory - commit-msg hook will be strict
echo "✅ Pre-commit checks passed"
exit 0
